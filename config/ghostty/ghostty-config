# Blue Archive / Hayase Yuuka — Ghostty config

# Font
font-family = JetBrainsMono Nerd Font
font-size = 13
font-style = Regular
font-style-bold = Bold
font-style-italic = Italic
font-style-bold-italic = Bold Italic

# Colors — BA palette
background = #00000A
foreground = #C8D8F0
cursor-color = #7FE7F5
cursor-style = bar
cursor-style-blink = true
selection-background = #1A2F45
selection-foreground = #E8F0FF

# 16 color palette
palette = 0=#0D1B2A
palette = 1=#FF6B8A
palette = 2=#5DDBB0
palette = 3=#FFD485
palette = 4=#4DB8FF
palette = 5=#B8A0FF
palette = 6=#7FE7F5
palette = 7=#C8D8F0
palette = 8=#1A2F45
palette = 9=#FF8FA6
palette = 10=#7EEFC8
palette = 11=#FFE0A0
palette = 12=#7FCFFF
palette = 13=#CDB8FF
palette = 14=#A0EEFA
palette = 15=#E8F0FF

# Window
window-decoration = false
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true

# No tab bar — using zellij for that
gtk-tabs-location = hidden
gtk-single-instance = false

# Performance
resize-overlay = never
mouse-hide-while-typing = true

# Shell integration
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# Misc
confirm-close-surface = false
copy-on-select = false
scrollback-limit = 10000
EOF